<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.gengrowth.baoxiao-daily</string>
    <key>ProgramArguments</key>
    <array>
        <string>@PYTHON@</string>
        <string>@BAOXIAO_DIR@/cli.py</string>
        <string>fetch-mail</string>
        <string>--filter-subject</string>
    </array>
    <key>WorkingDirectory</key>
    <string>@BAOXIAO_DIR@</string>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>19</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>@BAOXIAO_DIR@/logs/launchd-daily.log</string>
    <key>StandardErrorPath</key>
    <string>@BAOXIAO_DIR@/logs/launchd-daily.err</string>
    <key>RunAtLoad</key>
    <false/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
        <key>LC_ALL</key>
        <string>en_US.UTF-8</string>
        <key>PYTHONIOENCODING</key>
        <string>utf-8</string>
    </dict>
</dict>
</plist>
